---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../config/site';
---

<BaseLayout title="Not Found">
  <section class="shell page-intro">
    <div class="grid">
      <div class="page-intro__copy">
        <span class="eyebrow">404</span>
        <h1 class="title-1">Page Not Found</h1>
        <p class="summary">The requested URL does not exist.</p>
        <div style="margin-top: 32px; display: flex; gap: 16px;">
          <a class="btn btn-primary" href={withBase('/')}>Home</a>
          <a class="btn btn-outline" href={withBase('/blog/')}>Archive</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
