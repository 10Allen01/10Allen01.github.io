---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sectionMeta, withBase } from '../config/site';

const sections = Object.entries(sectionMeta);
---

<BaseLayout title="About" description="About the author.">
  <section class="shell page-intro">
    <div class="page-intro__ambient" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="page-intro__grid page-intro__grid--solo">
      <div class="page-intro__copy">
        <span class="eyebrow">About</span>
        <h1 class="title-1">Hello, I'm Allen.</h1>
        <p class="summary">I write about technology, network security, and practical tools.</p>
      </div>
    </div>
  </section>

  <section class="shell section">
    <div class="article-prose article-prose--panel">
      <p>
        Welcome to my personal archive. This site serves as a public notebook where I document my journey in software development and security research. It's built to be a fast, accessible, and structured place to share what I learn.
      </p>
      
      <h2 class="title-2">What I write about</h2>
      
      <div class="topic-grid">
        {sections.map(([id, meta]) => (
          <a class="topic-card" href={withBase(`/blog/?section=${id}`)}>
            <span class="topic-card__index">{id}</span>
            <h3 class="title-2">{meta.label}</h3>
            <p>{meta.description}</p>
          </a>
        ))}
      </div>

      <h2 class="title-2">Get in touch</h2>
      <p>
        If you want to connect, you can find me on <a href="https://github.com/10Allen01">GitHub</a> or <a href="https://www.instagram.com/sore.nvoss/">Instagram</a>.
      </p>
    </div>
  </section>
</BaseLayout>
