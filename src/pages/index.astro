---
import PostCard from '../components/PostCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig, sectionMeta, withBase } from '../config/site';
import { getAllTags, getFeaturedPosts, getPublishedPosts } from '../lib/posts';

const posts = await getPublishedPosts();
const featuredPost = getFeaturedPosts(posts, 1)[0] ?? posts[0];
const recentPosts = posts.filter(p => p.slug !== featuredPost?.slug).slice(0, 4);

const sections = Object.entries(sectionMeta).map(([key, meta]) => {
  return {
    id: key,
    ...meta,
    count: posts.filter(p => p.data.section === key).length
  };
});
---

<BaseLayout>
  <section class="shell page-intro">
    <div class="page-intro__ambient" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="page-intro__grid">
      <div class="page-intro__copy">
        <span class="eyebrow">{siteConfig.hero.eyebrow}</span>
        <h1 class="title-1">{siteConfig.hero.title}</h1>
        <p class="summary">{siteConfig.hero.summary}</p>

        <div class="hero-actions">
          <a class="btn btn-primary" href={withBase('/blog/')}>Archive</a>
          <a class="btn btn-outline" href={withBase('/about/')}>About Me</a>
        </div>
      </div>

      <aside class="coast-panel" aria-label="Site focus">
        <div class="coast-panel__orb" aria-hidden="true"></div>
        <div class="coast-panel__line">
          <span>Signal</span>
          <strong>Security</strong>
        </div>
        <div class="coast-panel__line">
          <span>Current</span>
          <strong>AI systems</strong>
        </div>
        <div class="coast-panel__line">
          <span>Shore</span>
          <strong>Practical code</strong>
        </div>
        <div class="coast-panel__tide" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section section--featured">
    <SectionHeading eyebrow="Featured" title="Latest post" />
    
    {featuredPost ? (
      <div class="post-grid">
        <PostCard post={featuredPost} featured />
      </div>
    ) : (
      <div class="empty-state">
        Nothing published yet.
      </div>
    )}
  </section>

  {recentPosts.length > 0 && (
    <section class="shell section">
      <SectionHeading eyebrow="Recent" title="New posts" actionHref="/blog/" actionLabel="View all" />

      <div class="post-grid">
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  )}

  <section class="shell section">
    <SectionHeading eyebrow="Categories" title="Browse by topic" />

    <div class="topic-grid">
      {sections.map((sec) => (
        <a class="topic-card" href={withBase(`/blog/?section=${sec.id}`)}>
          <span class="topic-card__index">{sec.id}</span>
          <h3 class="title-2">{sec.label}</h3>
          <p>{sec.description}</p>
          <span class="topic-card__count">
            {sec.count} {sec.count === 1 ? 'post' : 'posts'}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
