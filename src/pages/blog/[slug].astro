---
import { render } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sectionMeta, withBase } from '../../config/site';
import { formatDate, getPublishedPosts, getReadingTime, getRelatedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, posts }
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const relatedPosts = getRelatedPosts(posts, post, 2);
const meta = sectionMeta[post.data.section];
const cover = post.data.cover ? withBase(post.data.cover) : undefined;
const imageList = post.data.images.length ? post.data.images : [];
const hasInlinePostImages = /!\[[^\]]*\]\((?:\/images\/|https?:\/\/)/.test(post.body);
---

<BaseLayout title={post.data.title} description={post.data.excerpt} image={post.data.cover}>
  <article>
    <header class="article-header">
      <div class="shell">
        <div class="article-meta">
          <span>{meta.label}</span>
          <span>{formatDate(post.data.publishedAt)}</span>
          <span>{getReadingTime(post)} min read</span>
          {post.data.location && <span>{post.data.location}</span>}
        </div>
        <h1 class="title-1">{post.data.title}</h1>
        <div class="article-legal-chip">Publication-only notice: no authorization, facilitation, endorsement, or operational approval is created by this article.</div>
      </div>
    </header>

    {cover && (
      <div class="article-media-shell">
        <img class="article-media" src={cover} alt={post.data.coverAlt || post.data.title} />
      </div>
    )}

    <div class="shell">
      <aside class="article-warning" role="note" aria-label="High-risk content notice">
        <div class="article-warning__header">
          <span class="eyebrow">High-Risk Content Notice</span>
          <h2 class="title-2">This article is publication-only and creates no authorization, operational approval, or facilitation rights.</h2>
        </div>
        <p>This article is published only as informational, documentary, research, analytical, or archival material. Its presence on this website does not create permission, facilitation, endorsement, implementation support, technical assistance, or any operator-backed right to use, reproduce, deploy, adapt, or act upon the material in unauthorized or unlawful ways.</p>
        <p>If any person later uses, republishes, automates, operationalizes, adapts, or misuses anything discussed or referenced here for unauthorized, harmful, or illegal purposes, that conduct is independent of this website, outside the operator's control, and carried out without the operator's authorization, participation, approval, assistance, or legal responsibility. As a secondary point only, the operator also does not morally condone such conduct.</p>
      </aside>
      <div class="article-prose">
        <Content />

        <aside class="article-reference-disclaimer" role="note" aria-label="External links and tool reference disclaimer">
          <div class="article-reference-disclaimer__header">
            <span class="eyebrow">External Links and Tool References</span>
            <h2 class="title-2">Reference does not mean endorsement, redistribution support, or operational authorization.</h2>
          </div>
          <p>Where this article cites external links, repositories, programs, scripts, utilities, services, or third-party tools, such references are provided only for commentary, documentation, research, archival record, or contextual citation. They do not constitute operator-backed deployment guidance, redistribution support, technical assistance, operator sponsorship, or approval for any downstream use.</p>
          <p>The inclusion of a name, link, repository, or tool reference does not mean that this website authored it, maintains it, verifies it, distributes it on behalf of its creator, guarantees its legality, or accepts responsibility for how any third party later downloads, republishes, adapts, deploys, or misuses it. Reference alone does not create legal reliance rights against the website operator.</p>
        </aside>

        {imageList.length > 0 && !hasInlinePostImages && (
          <div class="post-grid" style="margin-top: 80px;">
            {imageList.map((image) => (
              <img src={withBase(image.src)} alt={image.alt || post.data.title} style="width: 100%; height: auto; margin: 0; border: 1px solid var(--border);" loading="lazy" />
            ))}
          </div>
        )}

        <div class="tag-cloud" style="margin-top: 80px; padding-top: 40px; border-top: 1px solid var(--border);">
          {post.data.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </article>

  {relatedPosts.length > 0 && (
    <section class="shell section">
      <h2 class="title-2" style="text-align: center; margin-bottom: 60px;">Related reading</h2>
      <div class="post-grid">
        {relatedPosts.map((relatedPost) => (
          <PostCard post={relatedPost} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
