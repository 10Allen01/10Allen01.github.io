---
import '../styles/global.css';
import BackgroundMusic from '../components/BackgroundMusic.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig, withBase } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageClass?: string;
}

const {
  title,
  description = siteConfig.description,
  image,
  pageClass = ''
} = Astro.props;

const musicBarOn = siteConfig.backgroundMusic.enabled === true;
const pageTitle = title ? `${title} | ${siteConfig.title}` : `${siteConfig.title} | ${siteConfig.tagline}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = image
  ? new URL(image.startsWith('http') ? image : withBase(image), Astro.site ?? Astro.url).toString()
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9fbff" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <script is:inline>
      (function () {
        const navKey = 'allen.site.internalNav';
        const sessionKey = 'allen.site.sessionEntered';
        let shouldAnimate = true;

        try {
          const rawReferrer = document.referrer;
          const referrer = rawReferrer ? new URL(rawReferrer, window.location.href) : null;
          const isSameOriginReferrer = !!referrer && referrer.origin === window.location.origin;
          const hasInternalNavMarker = sessionStorage.getItem(navKey) === '1';
          const hasEnteredThisSession = sessionStorage.getItem(sessionKey) === '1';

          shouldAnimate = !(hasInternalNavMarker || isSameOriginReferrer || hasEnteredThisSession);
          sessionStorage.setItem(sessionKey, '1');
          sessionStorage.removeItem(navKey);
        } catch {
          shouldAnimate = true;
        }

        window.__allenEntryLoaderShouldAnimate = shouldAnimate;
        document.documentElement.classList.add(shouldAnimate ? 'site-entry-pending' : 'site-entry-skip');
      })();
    </script>
    <slot name="head" />
  </head>
  <body class:list={['site-shell', pageClass, musicBarOn && 'site-shell--music-bar']}>
    <div id="entry-loader" class="entry-loader" aria-hidden="true">
      <div class="entry-loader__wash"></div>
      <div class="entry-loader__aurora"></div>
      <div class="entry-loader__grid"></div>
      <div class="entry-loader__grain"></div>
      <div class="entry-loader__core">
        <span class="entry-loader__halo"></span>
        <span class="entry-loader__ring entry-loader__ring--outer"></span>
        <span class="entry-loader__ring entry-loader__ring--inner"></span>
        <span class="entry-loader__spark entry-loader__spark--a"></span>
        <span class="entry-loader__spark entry-loader__spark--b"></span>
        <span class="entry-loader__spark entry-loader__spark--c"></span>
        <span class="entry-loader__pulse"></span>
        <span class="entry-loader__brand">{siteConfig.title}</span>
        <span class="entry-loader__subtitle">Digital archive · Security · AI · Code</span>
        <span class="entry-loader__beam"></span>
      </div>
    </div>
    <div id="site-frame">
      <SiteHeader />
      <main class="page-main">
        <slot />
      </main>
      <SiteFooter />
    </div>
    <BackgroundMusic />
    <script is:inline>
      (function () {
        const root = document.getElementById('entry-loader');
        const frame = document.getElementById('site-frame');
        if (!root || !frame) return;

        const doc = document.documentElement;
        const navKey = 'allen.site.internalNav';
        const shouldAnimate = window.__allenEntryLoaderShouldAnimate === true;
        const headSyncSelectors = [
          'link[rel="canonical"]',
          'meta[name="description"]',
          'meta[property="og:title"]',
          'meta[property="og:description"]',
          'meta[property="og:url"]',
          'meta[property="og:image"]',
          'meta[name="twitter:title"]',
          'meta[name="twitter:description"]',
          'meta[name="twitter:image"]'
        ];

        let navController = null;
        let navRequestId = 0;
        const prefetchedPages = new Map();
        const prefetchedStyles = new Set();
        const PREFETCH_LIMIT = 12;

        const markInternalNavigation = () => {
          try {
            sessionStorage.setItem(navKey, '1');
          } catch {
            /* empty */
          }
        };

        const canHandleNavigationEvent = (event) => {
          if (event.defaultPrevented || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
            return false;
          }

          if ('button' in event && typeof event.button === 'number' && event.button !== 0) {
            return false;
          }

          return true;
        };

        const handleInternalNavigationIntent = (event) => {
            if (!canHandleNavigationEvent(event)) {
              return;
            }

            const target = event.target;
            if (!(target instanceof Element)) return;

            const anchor = target.closest('a[href]');
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (anchor.target && anchor.target !== '_self') return;
            if (anchor.hasAttribute('download')) return;

            let url;
            try {
              url = new URL(anchor.href, window.location.href);
            } catch {
              return;
            }

            if (url.origin !== window.location.origin) return;
            if (url.pathname === window.location.pathname && url.search === window.location.search) return;

            markInternalNavigation();
            prefetchPage(url);
          };

        const normalizeUrl = (url) => {
          const normalized = new URL(url.href);
          normalized.hash = '';
          return normalized.href;
        };

        const getInternalUrl = (anchor) => {
          if (!(anchor instanceof HTMLAnchorElement)) return null;
          if (!anchor.href || anchor.target && anchor.target !== '_self') return null;
          if (anchor.hasAttribute('download') || anchor.getAttribute('rel') === 'external') return null;

          let url;
          try {
            url = new URL(anchor.href, window.location.href);
          } catch {
            return null;
          }

          if (url.origin !== window.location.origin) return null;
          if (url.protocol !== 'http:' && url.protocol !== 'https:') return null;
          return url;
        };

        const syncHeadTag = (nextDoc, selector) => {
          const nextTag = nextDoc.querySelector(selector);
          const currentTag = document.querySelector(selector);

          if (!nextTag) {
            currentTag?.remove();
            return;
          }

          if (!currentTag) {
            document.head.appendChild(nextTag.cloneNode(true));
            return;
          }

          if (currentTag.tagName === 'LINK') {
            const href = nextTag.getAttribute('href');
            if (href) {
              currentTag.setAttribute('href', href);
            } else {
              currentTag.removeAttribute('href');
            }
            return;
          }

          const content = nextTag.getAttribute('content');
          if (content !== null) {
            currentTag.setAttribute('content', content);
          } else {
            currentTag.removeAttribute('content');
          }
        };

        const prefetchStylesheets = (nextDoc) => {
          const headHrefs = new Set(
            Array.from(document.querySelectorAll('head link[href]')).map((link) =>
              new URL(link.getAttribute('href') || '', window.location.href).href
            )
          );

          Array.from(nextDoc.querySelectorAll('head link[rel="stylesheet"][href]')).forEach((link) => {
            const href = new URL(link.getAttribute('href') || '', window.location.href).href;

            if (headHrefs.has(href) || prefetchedStyles.has(href)) {
              return;
            }

            const preload = document.createElement('link');
            preload.rel = 'preload';
            preload.as = 'style';
            preload.href = href;
            document.head.appendChild(preload);
            prefetchedStyles.add(href);
          });
        };

        const fetchPage = (url) => {
          const key = normalizeUrl(url);
          const cached = prefetchedPages.get(key);
          if (cached) {
            return cached;
          }

          const pending = fetch(key, {
            headers: {
              'X-Allen-Navigation': '1'
            }
          })
            .then(async (response) => {
              if (!response.ok) {
                throw new Error('fetch_failed');
              }

              const html = await response.text();
              const nextDoc = new DOMParser().parseFromString(html, 'text/html');
              const nextFrame = nextDoc.getElementById('site-frame');

              if (!(nextFrame instanceof HTMLElement) || !(nextDoc.body instanceof HTMLBodyElement)) {
                throw new Error('frame_missing');
              }

              prefetchStylesheets(nextDoc);
              return { nextDoc };
            })
            .catch((error) => {
              prefetchedPages.delete(key);
              throw error;
            });

          prefetchedPages.set(key, pending);
          return pending;
        };

        const prefetchPage = (url) => {
          fetchPage(url).catch(() => {
            return null;
          });
        };

        const scheduleLinkPrefetch = () => {
          const seen = new Set();
          let count = 0;

          Array.from(frame.querySelectorAll('a[href]')).forEach((anchor) => {
            if (count >= PREFETCH_LIMIT) {
              return;
            }

            const url = getInternalUrl(anchor);
            if (!url) return;
            if (url.pathname === window.location.pathname && url.search === window.location.search) return;

            const key = normalizeUrl(url);
            if (seen.has(key)) return;

            seen.add(key);
            count += 1;
            prefetchPage(url);
          });
        };

        const syncStylesheets = async (nextDoc) => {
          const currentLinks = Array.from(document.querySelectorAll('head link[rel="stylesheet"][href]'));
          const nextLinks = Array.from(nextDoc.querySelectorAll('head link[rel="stylesheet"][href]'));
          const currentMap = new Map(
            currentLinks.map((link) => [new URL(link.getAttribute('href') || '', window.location.href).href, link])
          );
          const nextHrefs = nextLinks.map((link) => new URL(link.getAttribute('href') || '', window.location.href).href);

          await Promise.all(
            nextLinks.map((link) => {
              const href = new URL(link.getAttribute('href') || '', window.location.href).href;
              if (currentMap.has(href)) {
                return Promise.resolve();
              }

              return new Promise((resolve) => {
                const clone = document.createElement('link');
                clone.rel = 'stylesheet';
                clone.href = href;
                clone.onload = () => resolve();
                clone.onerror = () => resolve();
                document.head.appendChild(clone);
              });
            })
          );

          currentMap.forEach((link, href) => {
            if (!nextHrefs.includes(href)) {
              link.remove();
            }
          });
        };

        const runFrameScripts = () => {
          const scripts = Array.from(frame.querySelectorAll('script'));

          scripts.forEach((oldScript) => {
            const newScript = document.createElement('script');

            Array.from(oldScript.attributes).forEach((attribute) => {
              newScript.setAttribute(attribute.name, attribute.value);
            });

            newScript.textContent = oldScript.textContent;
            oldScript.replaceWith(newScript);
          });
        };

        const syncHead = async (nextDoc) => {
          document.title = nextDoc.title;
          doc.lang = nextDoc.documentElement.lang || doc.lang;

          await syncStylesheets(nextDoc);
          headSyncSelectors.forEach((selector) => syncHeadTag(nextDoc, selector));
        };

        const scrollToTarget = (url) => {
          if (url.hash) {
            const targetId = decodeURIComponent(url.hash.slice(1));
            const target = document.getElementById(targetId);
            if (target) {
              target.scrollIntoView();
              return;
            }
          }

          window.scrollTo(0, 0);
        };

        const navigateTo = async (url, options = {}) => {
          if (navController) {
            navController.abort();
          }

          navController = new AbortController();
          const requestId = ++navRequestId;
          markInternalNavigation();

          try {
            const prepared = await fetchPage(url);
            if (requestId !== navRequestId) {
              return;
            }

            const nextDoc = prepared.nextDoc;
            const nextFrame = nextDoc.getElementById('site-frame');

            if (!(nextFrame instanceof HTMLElement) || !(nextDoc.body instanceof HTMLBodyElement)) {
              window.location.href = url.href;
              return;
            }

            await syncHead(nextDoc);
            if (requestId !== navRequestId) {
              return;
            }

            document.body.className = nextDoc.body.className;
            frame.innerHTML = nextFrame.innerHTML;
            runFrameScripts();
            window.setTimeout(scheduleLinkPrefetch, 0);

            try {
              sessionStorage.removeItem(navKey);
            } catch {
              /* empty */
            }

            if (options.updateHistory !== false) {
              const historyMethod = options.replace === true ? 'replaceState' : 'pushState';
              window.history[historyMethod]({}, '', url.href);
            }

            scrollToTarget(url);
            document.dispatchEvent(new CustomEvent('allen:navigation-complete', { detail: { href: url.href } }));
          } catch (error) {
            if (error && typeof error === 'object' && 'name' in error && error.name === 'AbortError') {
              return;
            }

            window.location.href = url.href;
          }
        };

        document.addEventListener('pointerdown', handleInternalNavigationIntent, { capture: true, passive: true });
        document.addEventListener('touchstart', handleInternalNavigationIntent, { capture: true, passive: true });
        document.addEventListener(
          'click',
          (event) => {
            handleInternalNavigationIntent(event);

            if (!canHandleNavigationEvent(event)) {
              return;
            }

            const target = event.target;
            if (!(target instanceof Element)) return;

            const anchor = target.closest('a[href]');
            const url = getInternalUrl(anchor);
            if (!url) return;

            if (url.pathname === window.location.pathname && url.search === window.location.search) {
              return;
            }

            event.preventDefault();
            navigateTo(url);
          },
          { capture: true }
        );

        window.addEventListener('popstate', () => {
          navigateTo(new URL(window.location.href), { updateHistory: false, replace: true });
        });

        window.history.replaceState({}, '', window.location.href);
        window.setTimeout(scheduleLinkPrefetch, 0);

        if (!shouldAnimate) {
          doc.classList.remove('site-entry-pending');
          doc.classList.add('site-entry-skip');
          root.setAttribute('hidden', '');
          return;
        }

        let finished = false;

        const finish = () => {
          if (finished) return;
          finished = true;
          root.classList.add('is-exit');
          doc.classList.remove('site-entry-pending');
          doc.classList.add('site-entry-done');

          window.setTimeout(() => {
            root.setAttribute('hidden', '');
          }, 900);
        };

        requestAnimationFrame(() => {
          root.classList.add('is-active');
        });

        if (document.readyState === 'complete') {
          window.setTimeout(finish, 1850);
        } else {
          window.addEventListener(
            'load',
            () => {
              window.setTimeout(finish, 1850);
            },
            { once: true }
          );
        }

        window.setTimeout(finish, 4200);
      })();
    </script>
  </body>
</html>
