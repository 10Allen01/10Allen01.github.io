---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import BackgroundMusic from '../components/BackgroundMusic.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig, withBase } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageClass?: string;
}

const {
  title,
  description = siteConfig.description,
  image,
  pageClass = ''
} = Astro.props;

const musicBarOn = siteConfig.backgroundMusic.enabled === true;
const pageTitle = title ? `${title} | ${siteConfig.title}` : `${siteConfig.title} | ${siteConfig.tagline}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = image
  ? new URL(image.startsWith('http') ? image : withBase(image), Astro.site ?? Astro.url).toString()
  : undefined;
const buildId = (process.env.GITHUB_SHA || process.env.VERCEL_GIT_COMMIT_SHA || process.env.COMMIT_REF || 'dev').slice(0, 12);
const versionUrl = withBase('/version.json');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9fbff" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <meta name="allen-build-id" content={buildId} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <script is:inline define:vars={{ buildId, versionUrl }}>
      (function () {
        if (buildId === 'dev') return;

        const storageKey = 'allen.site.latestBuild';

        try {
          const url = new URL(window.location.href);
          if (url.searchParams.get('v') === buildId) {
            url.searchParams.delete('v');
            window.history.replaceState({}, '', url.toString());
          }
        } catch {}

        window.setTimeout(function () {
          fetch(`${versionUrl}?t=${Date.now()}`, { cache: 'no-store' })
            .then(function (response) {
              if (!response.ok) return null;
              return response.json();
            })
            .then(function (payload) {
              const latestBuild = payload && typeof payload.buildId === 'string' ? payload.buildId : '';
              if (!latestBuild) return;

              try {
                localStorage.setItem(storageKey, latestBuild);
              } catch {}

              if (latestBuild === buildId) {
                return;
              }

              const nextUrl = new URL(window.location.href);
              nextUrl.searchParams.set('v', latestBuild);
              window.location.replace(nextUrl.toString());
            })
            .catch(function () {
              try {
                const latestBuild = localStorage.getItem(storageKey);
                if (!latestBuild || latestBuild === buildId) {
                  return;
                }

                const nextUrl = new URL(window.location.href);
                nextUrl.searchParams.set('v', latestBuild);
                window.location.replace(nextUrl.toString());
              } catch {}
            });
        }, 0);
      })();
    </script>
    <script is:inline>
      (function () {
        const navKey = 'allen.site.internalNav';
        const sessionKey = 'allen.site.sessionEntered';
        const navMarkerTtlMs = 2500;
        let shouldAnimate = true;

        const hasFreshInternalNavMarker = () => {
          try {
            const raw = sessionStorage.getItem(navKey);
            const timestamp = Number(raw);
            if (!Number.isFinite(timestamp)) return false;
            if (Date.now() - timestamp > navMarkerTtlMs) {
              sessionStorage.removeItem(navKey);
              return false;
            }
            return true;
          } catch {
            return false;
          }
        };

        try {
          const rawReferrer = document.referrer;
          const referrer = rawReferrer ? new URL(rawReferrer, window.location.href) : null;
          const isSameOriginReferrer = !!referrer && referrer.origin === window.location.origin;
          const hasInternalNavMarker = hasFreshInternalNavMarker();
          const hasEnteredThisSession = sessionStorage.getItem(sessionKey) === '1';

          shouldAnimate = !(hasInternalNavMarker || isSameOriginReferrer || hasEnteredThisSession);
          sessionStorage.setItem(sessionKey, '1');
          sessionStorage.removeItem(navKey);
        } catch {
          shouldAnimate = true;
        }

        window.__allenEntryLoaderShouldAnimate = shouldAnimate;
        document.documentElement.classList.add(shouldAnimate ? 'site-entry-pending' : 'site-entry-skip');
      })();
    </script>
    <slot name="head" />
  </head>
  <body class:list={['site-shell', pageClass, musicBarOn && 'site-shell--music-bar']}>
    <div id="entry-loader" class="entry-loader" aria-hidden="true">
      <div class="entry-loader__wash"></div>
      <div class="entry-loader__aurora"></div>
      <div class="entry-loader__grid"></div>
      <div class="entry-loader__grain"></div>
      <div class="entry-loader__core">
        <span class="entry-loader__halo"></span>
        <span class="entry-loader__ring entry-loader__ring--outer"></span>
        <span class="entry-loader__ring entry-loader__ring--inner"></span>
        <span class="entry-loader__spark entry-loader__spark--a"></span>
        <span class="entry-loader__spark entry-loader__spark--b"></span>
        <span class="entry-loader__spark entry-loader__spark--c"></span>
        <span class="entry-loader__pulse"></span>
        <span class="entry-loader__brand">{siteConfig.title}</span>
        <span class="entry-loader__subtitle">Digital archive · Security · AI · Code</span>
        <span class="entry-loader__beam"></span>
      </div>
    </div>
    <SiteHeader />
    <section class="shell site-operator-banner-wrap" aria-label="Operator protection notice">
      <div class="site-operator-banner" role="note">
        <span class="site-operator-banner__label">Operator Protection Notice</span>
        <p class="site-operator-banner__text">This website is a publication only. Nothing published here grants authorization, operational approval, facilitation, endorsement, or instruction for unauthorized or unlawful conduct, and no downstream third-party misuse is attributable to the website operator.</p>
      </div>
    </section>
    <section id="visit-shield-wrap" class="visit-shield-wrap" aria-label="First-visit acknowledgment">
      <div id="visit-shield" class="shell visit-shield" role="dialog" aria-labelledby="visit-shield-title" aria-live="polite" aria-modal="true">
        <div class="visit-shield__copy">
          <span class="visit-shield__label">First-Visit Acknowledgment</span>
          <h2 id="visit-shield-title" class="title-2">Acknowledgment required: this website is an informational publication for lawful study, documentation, research, and authorized testing contexts only.</h2>
          <p class="visit-shield__text">By continuing, you acknowledge that nothing published here creates permission, operational support, approval, facilitation, partnership, or reliance rights for unlawful or unauthorized activity. Any later misuse, redistribution, automation, or illegal deployment by any third party is independent of this website and is not legally attributable to the website operator.</p>
        </div>
        <button class="btn btn-primary visit-shield__button" id="visit-shield-dismiss" type="button">I understand</button>
      </div>
    </section>
    <main class="page-main">
      <slot />
    </main>
    <section class="shell site-disclaimer-wrap" aria-labelledby="site-disclaimer-title">
      <div class="site-disclaimer" role="note" aria-label="Legal disclaimer">
        <div class="site-disclaimer__header">
          <span class="eyebrow">Legal Notice</span>
          <h2 id="site-disclaimer-title" class="title-2">Strict Publication-Only, No-Authorization, and Full Operator Liability Disclaimer</h2>
        </div>
        <p class="site-disclaimer__lead">This website is an informational, educational, documentary, and archival publication only. Any teaching material, technical note, referenced program, script, workflow, demonstration, external link, or linked resource appearing here is made available solely within a publication context for lawful study, documentation, research, analysis, defensive awareness, and properly authorized testing. Publication here does not create permission, operational approval, facilitation, service provision, sponsorship, endorsement, distribution authority, or reliance rights in favor of any reader or third party.</p>
        <div class="site-disclaimer__grid">
          <p>No article, note, quote, screenshot, code fragment, linked program, referenced tool, demonstration, archive entry, or technical discussion on this website shall be construed as a license, request, solicitation, inducement, instruction, invitation, facilitation service, partnership offer, agency relationship, conspiracy, coordinated undertaking, operational approval, or knowing encouragement for any person to engage in unauthorized access, privacy violation, circumvention, disruption, surveillance, credential misuse, exploitation, or any other unlawful or abusive act.</p>
          <p>Publication of material here does not convert the website operator into a distributor on behalf of third parties, a service provider for downstream use, a sponsor of implementation, a technical support point, a legal approver, or a participant in any later conduct undertaken by a visitor, downloader, scraper, mirror, republisher, or outside actor.</p>
          <p>Where programs, utilities, repositories, services, or external resources are mentioned, they are mentioned only as objects of reference, commentary, citation, criticism, documentation, analysis, or archival record. Such mention does not mean that the website operator authored them, controls them, maintains them, endorses them, redistributes them on behalf of others, verifies their legality, guarantees their safety, or adopts any downstream action taken by people who later obtain or misuse them elsewhere.</p>
          <p>The website operator does not control what any visitor, scraper, mirror, republisher, downloader, channel, platform, or outside actor may do after encountering content here. Any later reposting, redistribution, operational deployment, malicious adaptation, unlawful use, or harmful exploitation by any third party is independent of this website, beyond its control, and undertaken without the website operator's authorization, participation, direction, approval, assistance, or ratification.</p>
          <p>No person may reasonably attribute third-party misconduct to the mere fact that educational or technical material was published here in a publication context. Publication for study, documentation, analysis, or authorized testing does not transform the website operator into a participant, accomplice, co-actor, service provider, sponsor, approver, or legally responsible party in relation to any later illegal act committed by someone else.</p>
          <p>All materials are provided strictly as-is and as-available, without representation or warranty as to legality, safety, completeness, accuracy, fitness for purpose, current validity, downstream outcome, or third-party conduct. The website operator assumes no duty to monitor third-party use, no duty to prevent independent misuse by outsiders, no duty to remove every referenced item in anticipation of misuse, and no duty to guarantee that referenced or discussed material will not be abused by persons acting contrary to law or authorization boundaries.</p>
          <p>As an additional and secondary point, the website operator does not condone or morally align with malicious, harmful, intrusive, or unlawful use derived by any third party from material discussed, linked, summarized, or archived on this website.</p>
          <p>To the fullest extent permitted by applicable law, the website operator, author, and any related contributors expressly disclaim all legal, civil, criminal, contractual, regulatory, technical, financial, reputational, data-related, privacy-related, and consequential responsibility or liability for any third-party misuse, unlawful deployment, unauthorized exploitation, or harmful operational use allegedly connected to materials published on or linked from this website.</p>
        </div>
      </div>
    </section>
    <SiteFooter />
    <BackgroundMusic />
    <script is:inline>
      (function () {
        const storageKey = 'allen.site.visitShieldAccepted';

        const readAcceptedState = () => {
          try {
            if (window.localStorage.getItem(storageKey) === '1') {
              return true;
            }
          } catch {
            /* empty */
          }

          try {
            return window.sessionStorage.getItem(storageKey) === '1';
          } catch {
            return false;
          }
        };

        const writeAcceptedState = () => {
          try {
            window.localStorage.setItem(storageKey, '1');
          } catch {
            /* empty */
          }

          try {
            window.sessionStorage.setItem(storageKey, '1');
          } catch {
            /* empty */
          }
        };

        const initVisitShield = () => {
          const wrap = document.getElementById('visit-shield-wrap');
          const shield = document.getElementById('visit-shield');
          const dismissButton = document.getElementById('visit-shield-dismiss');
          if (!(wrap instanceof HTMLElement) || !(shield instanceof HTMLElement) || !(dismissButton instanceof HTMLButtonElement)) {
            return;
          }

          const setVisible = (visible) => {
            wrap.hidden = !visible;
            shield.hidden = !visible;
            shield.setAttribute('aria-hidden', visible ? 'false' : 'true');
            document.body.classList.toggle('visit-shield-open', visible);
          };

          setVisible(!readAcceptedState());

          if (dismissButton.dataset.bound === '1') {
            return;
          }

          dismissButton.dataset.bound = '1';
          dismissButton.addEventListener('click', () => {
            writeAcceptedState();
            setVisible(false);
          });
        };

        if (window.__allenVisitShieldBound !== true) {
          document.addEventListener('astro:page-load', initVisitShield);
          document.addEventListener('astro:after-swap', initVisitShield);
          window.addEventListener('pageshow', initVisitShield);
          window.__allenVisitShieldBound = true;
        }

        initVisitShield();
      })();
    </script>
    <script is:inline>
      (function () {
        const root = document.getElementById('entry-loader');
        if (!root) return;

        const doc = document.documentElement;
        const navKey = 'allen.site.internalNav';
        const navMarkerTtlMs = 2500;
        const shouldAnimate = window.__allenEntryLoaderShouldAnimate === true;

        const clearInternalNavigation = () => {
          try {
            sessionStorage.removeItem(navKey);
          } catch {
            /* empty */
          }
        };

        const scheduleInternalNavigationClear = () => {
          const existingTimer = window.__allenInternalNavClearTimer;
          if (typeof existingTimer === 'number') {
            window.clearTimeout(existingTimer);
          }

          window.__allenInternalNavClearTimer = window.setTimeout(() => {
            clearInternalNavigation();
            window.__allenInternalNavClearTimer = null;
          }, navMarkerTtlMs);
        };

        const markInternalNavigation = () => {
          try {
            sessionStorage.setItem(navKey, String(Date.now()));
          } catch {
            /* empty */
          }

          scheduleInternalNavigationClear();
        };

        const handleInternalNavigationIntent = (event) => {
            if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
              return;
            }

            const target = event.target;
            if (!(target instanceof Element)) return;

            const anchor = target.closest('a[href]');
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (anchor.target && anchor.target !== '_self') return;
            if (anchor.hasAttribute('download')) return;

            let url;
            try {
              url = new URL(anchor.href, window.location.href);
            } catch {
              return;
            }

            if (url.origin !== window.location.origin) return;
            if (url.pathname === window.location.pathname && url.search === window.location.search) return;

            markInternalNavigation();
          };

        document.addEventListener('pointerdown', handleInternalNavigationIntent, { capture: true });
        document.addEventListener('click', handleInternalNavigationIntent, { capture: true });
        document.addEventListener('astro:after-swap', clearInternalNavigation);
        document.addEventListener('astro:page-load', clearInternalNavigation);
        window.addEventListener('pageshow', clearInternalNavigation);
        scheduleInternalNavigationClear();

        if (!shouldAnimate) {
          doc.classList.remove('site-entry-pending');
          doc.classList.add('site-entry-skip');
          root.setAttribute('hidden', '');
          return;
        }

        let finished = false;

        const finish = () => {
          if (finished) return;
          finished = true;
          root.classList.add('is-exit');
          doc.classList.remove('site-entry-pending');
          doc.classList.add('site-entry-done');

          window.setTimeout(() => {
            root.setAttribute('hidden', '');
          }, 900);
        };

        requestAnimationFrame(() => {
          root.classList.add('is-active');
        });

        if (document.readyState === 'complete') {
          window.setTimeout(finish, 1850);
        } else {
          window.addEventListener(
            'load',
            () => {
              window.setTimeout(finish, 1850);
            },
            { once: true }
          );
        }

        window.setTimeout(finish, 4200);
      })();
    </script>
  </body>
</html>
