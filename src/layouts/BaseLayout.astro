---
import '../styles/global.css';
import BackgroundMusic from '../components/BackgroundMusic.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig, withBase } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageClass?: string;
}

const {
  title,
  description = siteConfig.description,
  image,
  pageClass = ''
} = Astro.props;

const musicBarOn = siteConfig.backgroundMusic.enabled === true;
const pageTitle = title ? `${title} | ${siteConfig.title}` : `${siteConfig.title} | ${siteConfig.tagline}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = image
  ? new URL(image.startsWith('http') ? image : withBase(image), Astro.site ?? Astro.url).toString()
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9fbff" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <slot name="head" />
  </head>
  <body class:list={['site-shell', pageClass, musicBarOn && 'site-shell--music-bar']}>
    <SiteHeader />
    <main class="page-main">
      <slot />
    </main>
    <SiteFooter />
    <BackgroundMusic />
  </body>
</html>
