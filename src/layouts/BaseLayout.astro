---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import BackgroundMusic from '../components/BackgroundMusic.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig, withBase } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageClass?: string;
}

const {
  title,
  description = siteConfig.description,
  image,
  pageClass = ''
} = Astro.props;

const musicBarOn = siteConfig.backgroundMusic.enabled === true;
const pageTitle = title ? `${title} | ${siteConfig.title}` : `${siteConfig.title} | ${siteConfig.tagline}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = image
  ? new URL(image.startsWith('http') ? image : withBase(image), Astro.site ?? Astro.url).toString()
  : undefined;
const buildId = (process.env.GITHUB_SHA || process.env.VERCEL_GIT_COMMIT_SHA || process.env.COMMIT_REF || 'dev').slice(0, 12);
const versionUrl = withBase('/version.json');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <ViewTransitions />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f9fbff" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <meta name="allen-build-id" content={buildId} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <script is:inline define:vars={{ buildId, versionUrl }}>
      (function () {
        if (buildId === 'dev') return;

        const storageKey = 'allen.site.latestBuild';

        try {
          const url = new URL(window.location.href);
          if (url.searchParams.get('v') === buildId) {
            url.searchParams.delete('v');
            window.history.replaceState({}, '', url.toString());
          }
        } catch {}

        window.setTimeout(function () {
          fetch(`${versionUrl}?t=${Date.now()}`, { cache: 'no-store' })
            .then(function (response) {
              if (!response.ok) return null;
              return response.json();
            })
            .then(function (payload) {
              const latestBuild = payload && typeof payload.buildId === 'string' ? payload.buildId : '';
              if (!latestBuild) return;

              try {
                localStorage.setItem(storageKey, latestBuild);
              } catch {}

              if (latestBuild === buildId) {
                return;
              }

              const nextUrl = new URL(window.location.href);
              nextUrl.searchParams.set('v', latestBuild);
              window.location.replace(nextUrl.toString());
            })
            .catch(function () {
              try {
                const latestBuild = localStorage.getItem(storageKey);
                if (!latestBuild || latestBuild === buildId) {
                  return;
                }

                const nextUrl = new URL(window.location.href);
                nextUrl.searchParams.set('v', latestBuild);
                window.location.replace(nextUrl.toString());
              } catch {}
            });
        }, 0);
      })();
    </script>
    <script is:inline>
      (function () {
        const navKey = 'allen.site.internalNav';
        const sessionKey = 'allen.site.sessionEntered';
        const navMarkerTtlMs = 2500;
        let shouldAnimate = true;

        const hasFreshInternalNavMarker = () => {
          try {
            const raw = sessionStorage.getItem(navKey);
            const timestamp = Number(raw);
            if (!Number.isFinite(timestamp)) return false;
            if (Date.now() - timestamp > navMarkerTtlMs) {
              sessionStorage.removeItem(navKey);
              return false;
            }
            return true;
          } catch {
            return false;
          }
        };

        try {
          const rawReferrer = document.referrer;
          const referrer = rawReferrer ? new URL(rawReferrer, window.location.href) : null;
          const isSameOriginReferrer = !!referrer && referrer.origin === window.location.origin;
          const hasInternalNavMarker = hasFreshInternalNavMarker();
          const hasEnteredThisSession = sessionStorage.getItem(sessionKey) === '1';

          shouldAnimate = !(hasInternalNavMarker || isSameOriginReferrer || hasEnteredThisSession);
          sessionStorage.setItem(sessionKey, '1');
          sessionStorage.removeItem(navKey);
        } catch {
          shouldAnimate = true;
        }

        window.__allenEntryLoaderShouldAnimate = shouldAnimate;
        document.documentElement.classList.add(shouldAnimate ? 'site-entry-pending' : 'site-entry-skip');
      })();
    </script>
    <slot name="head" />
  </head>
  <body class:list={['site-shell', pageClass, musicBarOn && 'site-shell--music-bar']}>
    <div id="entry-loader" class="entry-loader" aria-hidden="true">
      <div class="entry-loader__wash"></div>
      <div class="entry-loader__aurora"></div>
      <div class="entry-loader__grid"></div>
      <div class="entry-loader__grain"></div>
      <div class="entry-loader__core">
        <span class="entry-loader__halo"></span>
        <span class="entry-loader__ring entry-loader__ring--outer"></span>
        <span class="entry-loader__ring entry-loader__ring--inner"></span>
        <span class="entry-loader__spark entry-loader__spark--a"></span>
        <span class="entry-loader__spark entry-loader__spark--b"></span>
        <span class="entry-loader__spark entry-loader__spark--c"></span>
        <span class="entry-loader__pulse"></span>
        <span class="entry-loader__brand">{siteConfig.title}</span>
        <span class="entry-loader__subtitle">Digital archive · Security · AI · Code</span>
        <span class="entry-loader__beam"></span>
      </div>
    </div>
    <SiteHeader />
    <section id="visit-shield-wrap" class="visit-shield-wrap" aria-label="First-visit acknowledgment" hidden>
      <div id="visit-shield" class="shell visit-shield" role="dialog" aria-labelledby="visit-shield-title" aria-live="polite" aria-modal="true" hidden>
        <div class="visit-shield__copy">
          <span class="visit-shield__label">Click-Wrap Required</span>
          <h2 id="visit-shield-title" class="title-2">Terms of Use, Disclaimer, and Indemnification Agreement</h2>
          <p class="visit-shield__text">Access to this website requires your agreement to the full Terms of Use, Disclaimer, and Indemnification Agreement.</p>
        </div>
        <div class="visit-shield__overview" role="document" aria-label="Terms summary">
          <div class="visit-shield__summary">
            <p>The full agreement includes Educational Purpose Only, No Warranty / As-Is, Assumption of Risk, Indemnification, Liquidated Damages, Governing Law &amp; Jurisdiction, Third-Party Tools Disclaimer, and No Professional Relationship terms.</p>
            <a class="btn btn-outline visit-shield__link" href={withBase('/agreement/')}>Review full agreement</a>
          </div>
        </div>
        <div class="visit-shield__actions">
          <label class="visit-shield__check" for="visit-shield-agree">
            <input id="visit-shield-agree" type="checkbox" />
            <span>I have read and agree to the Terms of Use, Disclaimer, and Indemnification Agreement.</span>
          </label>
          <button class="btn btn-primary visit-shield__button" id="visit-shield-dismiss" type="button" disabled>I agree and continue</button>
        </div>
      </div>
    </section>
    <main class="page-main">
      <slot />
    </main>
    <SiteFooter />
    <BackgroundMusic />
    <script is:inline>
      (function () {
        const storageKey = 'allen.site.visitShieldAccepted';
        const readyEventName = 'allen:entry-ready';

        const readAcceptedState = () => {
          try {
            if (window.localStorage.getItem(storageKey) === '1') {
              return true;
            }
          } catch {
            /* empty */
          }

          try {
            return window.sessionStorage.getItem(storageKey) === '1';
          } catch {
            return false;
          }
        };

        const writeAcceptedState = () => {
          try {
            window.localStorage.setItem(storageKey, '1');
          } catch {
            /* empty */
          }

          try {
            window.sessionStorage.setItem(storageKey, '1');
          } catch {
            /* empty */
          }
        };

        const initVisitShield = () => {
          const wrap = document.getElementById('visit-shield-wrap');
          const shield = document.getElementById('visit-shield');
          const dismissButton = document.getElementById('visit-shield-dismiss');
          const agreementCheckbox = document.getElementById('visit-shield-agree');
          if (!(wrap instanceof HTMLElement) || !(shield instanceof HTMLElement) || !(dismissButton instanceof HTMLButtonElement) || !(agreementCheckbox instanceof HTMLInputElement)) {
            return;
          }

          const entryPending = document.documentElement.classList.contains('site-entry-pending');

          const syncAgreementState = () => {
            const agreed = agreementCheckbox.checked === true;
            dismissButton.disabled = !agreed;
            dismissButton.setAttribute('aria-disabled', agreed ? 'false' : 'true');
          };

          const setVisible = (visible) => {
            wrap.hidden = !visible;
            shield.hidden = !visible;
            shield.setAttribute('aria-hidden', visible ? 'false' : 'true');
            document.body.classList.toggle('visit-shield-open', visible);
            if (visible) {
              agreementCheckbox.checked = false;
            }
            syncAgreementState();
          };

          const revealWhenReady = () => {
            setVisible(!readAcceptedState());
          };

          setVisible(false);

          if (!entryPending && (window.__allenEntryLoaderDone === true || window.__allenEntryLoaderShouldAnimate !== true)) {
            revealWhenReady();
          } else if (shield.dataset.waitingForEntry !== '1') {
            shield.dataset.waitingForEntry = '1';
            document.addEventListener(readyEventName, revealWhenReady, { once: true });
          }

          if (agreementCheckbox.dataset.bound !== '1') {
            agreementCheckbox.dataset.bound = '1';
            agreementCheckbox.addEventListener('change', syncAgreementState);
          }

          if (dismissButton.dataset.bound !== '1') {
            dismissButton.dataset.bound = '1';
            dismissButton.addEventListener('click', () => {
              if (agreementCheckbox.checked !== true) {
                syncAgreementState();
                return;
              }
              writeAcceptedState();
              setVisible(false);
            });
          }
        };

        if (window.__allenVisitShieldBound !== true) {
          document.addEventListener('astro:page-load', initVisitShield);
          document.addEventListener('astro:after-swap', initVisitShield);
          window.addEventListener('pageshow', initVisitShield);
          window.__allenVisitShieldBound = true;
        }

        initVisitShield();
      })();
    </script>
    <script is:inline>
      (function () {
        const root = document.getElementById('entry-loader');
        if (!root) return;

        const doc = document.documentElement;
        const navKey = 'allen.site.internalNav';
        const navMarkerTtlMs = 2500;
        const shouldAnimate = window.__allenEntryLoaderShouldAnimate === true;

        const clearInternalNavigation = () => {
          try {
            sessionStorage.removeItem(navKey);
          } catch {
            /* empty */
          }
        };

        const scheduleInternalNavigationClear = () => {
          const existingTimer = window.__allenInternalNavClearTimer;
          if (typeof existingTimer === 'number') {
            window.clearTimeout(existingTimer);
          }

          window.__allenInternalNavClearTimer = window.setTimeout(() => {
            clearInternalNavigation();
            window.__allenInternalNavClearTimer = null;
          }, navMarkerTtlMs);
        };

        const markInternalNavigation = () => {
          try {
            sessionStorage.setItem(navKey, String(Date.now()));
          } catch {
            /* empty */
          }

          scheduleInternalNavigationClear();
        };

        const handleInternalNavigationIntent = (event) => {
            if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
              return;
            }

            const target = event.target;
            if (!(target instanceof Element)) return;

            const anchor = target.closest('a[href]');
            if (!(anchor instanceof HTMLAnchorElement)) return;
            if (anchor.target && anchor.target !== '_self') return;
            if (anchor.hasAttribute('download')) return;

            let url;
            try {
              url = new URL(anchor.href, window.location.href);
            } catch {
              return;
            }

            if (url.origin !== window.location.origin) return;
            if (url.pathname === window.location.pathname && url.search === window.location.search) return;

            markInternalNavigation();
          };

        document.addEventListener('pointerdown', handleInternalNavigationIntent, { capture: true });
        document.addEventListener('click', handleInternalNavigationIntent, { capture: true });
        document.addEventListener('astro:after-swap', clearInternalNavigation);
        document.addEventListener('astro:page-load', clearInternalNavigation);
        window.addEventListener('pageshow', clearInternalNavigation);
        scheduleInternalNavigationClear();

        if (!shouldAnimate) {
          window.__allenEntryLoaderDone = true;
          doc.classList.remove('site-entry-pending');
          doc.classList.add('site-entry-skip');
          root.setAttribute('hidden', '');
          document.dispatchEvent(new CustomEvent('allen:entry-ready'));
          return;
        }

        let finished = false;

        const finish = () => {
          if (finished) return;
          finished = true;
          window.__allenEntryLoaderDone = true;
          root.classList.add('is-exit');
          doc.classList.remove('site-entry-pending');
          doc.classList.add('site-entry-done');
          document.dispatchEvent(new CustomEvent('allen:entry-ready'));

          window.setTimeout(() => {
            root.setAttribute('hidden', '');
          }, 900);
        };

        requestAnimationFrame(() => {
          root.classList.add('is-active');
        });

        if (document.readyState === 'complete') {
          window.setTimeout(finish, 1850);
        } else {
          window.addEventListener(
            'load',
            () => {
              window.setTimeout(finish, 1850);
            },
            { once: true }
          );
        }

        window.setTimeout(finish, 4200);
      })();
    </script>
  </body>
</html>
