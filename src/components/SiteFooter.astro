---
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell site-footer__inner">
    <div>
      <span>© {year} {siteConfig.author}</span>
      <p class="site-footer__notice">Nothing published here grants authorization, facilitation, endorsement, or operational approval for third-party conduct. Any later misuse, unauthorized deployment, or illegal use is independent of this website and is not legally attributable to its operator; as a secondary point only, it is also not morally condoned.</p>
    </div>

    <div class="site-footer__links">
      {siteConfig.socialLinks.map((link) => (
        <a href={link.href}>
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
