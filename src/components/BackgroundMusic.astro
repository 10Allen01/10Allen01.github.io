---
import { siteConfig } from '../config/site';

const bm = siteConfig.backgroundMusic;

if (!bm.enabled || bm.tracks.length === 0) {
  return;
}

const barLabel = bm.label ?? 'Now playing';
const tracksEnc = encodeURIComponent(JSON.stringify(bm.tracks));
const firstTitle = bm.tracks[0].title;
const showTrackNav = bm.tracks.length > 1;
---

<div id="music-root" class="music-bar" data-tracks-enc={tracksEnc} role="region" aria-label="Background music" transition:persist>
  <div class="music-bar__inner">
    <div class="music-bar__meta">
      <span class="music-bar__line">
        <span class="music-bar__eyebrow">{barLabel}</span>
        <span class="music-bar__sep" aria-hidden="true">·</span>
        <span id="music-title" class="music-bar__title">{firstTitle}</span>
      </span>
    </div>

    <div class:list={['music-bar__transport', !showTrackNav && 'music-bar__transport--single']}>
      {showTrackNav && (
        <button type="button" class="music-bar__btn" id="music-prev" aria-label="Previous track" title="Previous">
          <svg class="music-bar__icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 18V6h2v12H6zm3.5-6L18 6v12l-8.5-6z"/></svg>
        </button>
      )}
      <button type="button" class="music-bar__btn music-bar__btn--primary" id="music-toggle" aria-label="Pause" title="Pause">
        <svg class="music-bar__icon music-bar__icon--play hidden" id="music-icon-play" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7z"/></svg>
        <svg class="music-bar__icon music-bar__icon--pause" id="music-icon-pause" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 5h4v14H6V5zm8 0h4v14h-4V5z"/></svg>
      </button>
      {showTrackNav && (
        <button type="button" class="music-bar__btn" id="music-next" aria-label="Next track" title="Next">
          <svg class="music-bar__icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16 18h2V6h-2v12zm-9.5-6L15 6v12l-8.5-6z"/></svg>
        </button>
      )}
    </div>

    <div class="music-bar__volume">
      <label class="music-bar__vol-wrap">
        <span class="sr-only">Volume</span>
        <input type="range" id="music-volume" min="0" max="100" value="28" />
      </label>
    </div>
  </div>

  <audio id="music-audio" preload="auto" style="display: none;"></audio>
  <audio id="music-audio-alt" preload="auto" style="display: none;"></audio>
</div>

<script is:inline>
  (function () {
    const LS = 'allen.bgMusic';
    const NAV = 'allen.site.internalNav';
    const NAV_TTL_MS = 2500;
    const root = document.getElementById('music-root');
    const primaryAudio = document.getElementById('music-audio');
    const secondaryAudio = document.getElementById('music-audio-alt');
    if (!root || !root.dataset.tracksEnc || !(primaryAudio instanceof HTMLAudioElement) || !(secondaryAudio instanceof HTMLAudioElement)) return;
    if (root.dataset.initialized === '1') return;

    root.dataset.initialized = '1';

    let tracks;
    try {
      tracks = JSON.parse(decodeURIComponent(root.dataset.tracksEnc));
    } catch {
      return;
    }
    if (!Array.isArray(tracks) || tracks.length === 0) return;

    const titleEl = document.getElementById('music-title');
    const prevBtn = document.getElementById('music-prev');
    const nextBtn = document.getElementById('music-next');
    const toggleBtn = document.getElementById('music-toggle');
    const iconPlay = document.getElementById('music-icon-play');
    const iconPause = document.getElementById('music-icon-pause');
    const volInput = document.getElementById('music-volume');

    const DEFAULT_VOLUME = 28;
    const FADE_IN_MS = 1400;
    const FADE_OUT_MS = 450;
    const SWITCH_FADE_MS = 650;
    const FADE_TICK_MS = 50;
    const BLUR_PAUSE_DELAY_MS = 180;
    const PRELOAD_DELAY_MS = 180;

    let index = 0;
    let userPaused = false;
    let saveTimer = null;
    let blurPauseTimer = null;
    let preloadTimer = null;
    let autoplayBlocked = false;
    let resumeAfterReturn = false;
    let activeAudio = primaryAudio;
    let inactiveAudio = secondaryAudio;
    let switchTargetIndex = null;

    const fadeTimers = new WeakMap();
    const readyHandlers = new WeakMap();
    const audioTrackIndex = new WeakMap();

    function isInternalNavigationPending() {
      try {
        const raw = sessionStorage.getItem(NAV);
        const timestamp = Number(raw);
        if (!Number.isFinite(timestamp)) return false;
        if (Date.now() - timestamp > NAV_TTL_MS) {
          sessionStorage.removeItem(NAV);
          return false;
        }
        return true;
      } catch {
        return false;
      }
    }

    function setControlsEnabled(enabled) {
      prevBtn && (prevBtn.disabled = !enabled);
      nextBtn && (nextBtn.disabled = !enabled);
      toggleBtn && (toggleBtn.disabled = !enabled);
      volInput && (volInput.disabled = !enabled);
    }

    function getTargetVolume() {
      return Math.max(0, Math.min(100, Number(volInput?.value) || DEFAULT_VOLUME)) / 100;
    }

    function getCurrentVolume(audioEl) {
      return Math.max(0, Math.min(1, Number(audioEl?.volume) || 0));
    }

    function isAudioPlaying(audioEl) {
      return !!audioEl && !audioEl.paused && !audioEl.ended;
    }

    function clearFade(audioEl) {
      const timer = fadeTimers.get(audioEl);
      if (timer) {
        window.clearInterval(timer);
        fadeTimers.delete(audioEl);
      }
    }

    function clearAllFades() {
      clearFade(primaryAudio);
      clearFade(secondaryAudio);
    }

    function clearBlurPauseTimer() {
      if (blurPauseTimer) {
        window.clearTimeout(blurPauseTimer);
        blurPauseTimer = null;
      }
    }

    function clearPreloadTimer() {
      if (preloadTimer) {
        window.clearTimeout(preloadTimer);
        preloadTimer = null;
      }
    }

    function shouldPauseForBlur() {
      if (document.hidden || isInternalNavigationPending()) return false;
      if (typeof document.hasFocus === 'function' && document.hasFocus()) return false;
      return true;
    }

    function pauseElement(audioEl) {
      clearFade(audioEl);

      try {
        audioEl.volume = 0;
        audioEl.pause();
      } catch {
        /* ignore */
      }
    }

    function fadeVolumeTo(audioEl, target, duration, onDone) {
      if (!audioEl) {
        onDone?.();
        return;
      }

      clearFade(audioEl);

      const safeTarget = Math.max(0, Math.min(1, target));
      const from = getCurrentVolume(audioEl);
      const delta = safeTarget - from;

      if (Math.abs(delta) < 0.01) {
        try {
          if (safeTarget > 0) audioEl.muted = false;
          audioEl.volume = safeTarget;
        } catch {
          /* ignore */
        }
        onDone?.();
        return;
      }

      const startedAt = Date.now();

      const timer = window.setInterval(function () {
        const progress = Math.min(1, (Date.now() - startedAt) / duration);
        const next = from + delta * progress;

        try {
          if (safeTarget > 0) audioEl.muted = false;
          audioEl.volume = Math.max(0, Math.min(1, next));
        } catch {
          clearFade(audioEl);
          onDone?.();
          return;
        }

        if (progress >= 1) {
          clearFade(audioEl);
          try {
            if (safeTarget > 0) audioEl.muted = false;
            audioEl.volume = safeTarget;
          } catch {
            /* ignore */
          }
          onDone?.();
        }
      }, FADE_TICK_MS);

      fadeTimers.set(audioEl, timer);
    }

    function readStore() {
      try {
        const sessionValue = sessionStorage.getItem(LS);
        if (sessionValue) {
          return JSON.parse(sessionValue);
        }
      } catch {
        /* ignore */
      }

      try {
        const legacyValue = localStorage.getItem(LS);
        if (!legacyValue) return null;
        sessionStorage.setItem(LS, legacyValue);
        localStorage.removeItem(LS);
        return JSON.parse(legacyValue);
      } catch {
        return null;
      }
    }

    function writeStore(overrides) {
      try {
        const storeAudio = switchTargetIndex !== null && isAudioPlaying(inactiveAudio) ? inactiveAudio : activeAudio;
        const payload = {
          index: switchTargetIndex ?? index,
          t: Math.max(0, storeAudio.currentTime || 0),
          intent: userPaused ? 'pause' : 'play',
          vol: volInput ? Number(volInput.value) || DEFAULT_VOLUME : DEFAULT_VOLUME,
          at: Date.now(),
          ...overrides
        };
        sessionStorage.setItem(LS, JSON.stringify(payload));
      } catch {
        /* ignore */
      }

      try {
        localStorage.removeItem(LS);
      } catch {
        /* ignore */
      }
    }

    function setTitle(trackIndex = index) {
      if (titleEl && tracks[trackIndex]) titleEl.textContent = tracks[trackIndex].title;
    }

    function syncPlayUi(playing) {
      if (!toggleBtn) return;
      toggleBtn.setAttribute('aria-label', playing ? 'Pause' : 'Play');
      toggleBtn.setAttribute('title', playing ? 'Pause' : 'Play');
      iconPlay?.classList.toggle('hidden', !!playing);
      iconPause?.classList.toggle('hidden', !playing);
    }

    function clearReadyHandler(audioEl) {
      const handler = readyHandlers.get(audioEl);
      if (!handler) return;
      audioEl.removeEventListener('loadedmetadata', handler);
      audioEl.removeEventListener('canplay', handler);
      readyHandlers.delete(audioEl);
    }

    function loadTrack(audioEl, nextIndex, startTime = 0) {
      const track = tracks[nextIndex];
      if (!track) return;

      clearReadyHandler(audioEl);
      audioTrackIndex.set(audioEl, nextIndex);
      audioEl.loop = true;

      if (audioEl.getAttribute('src') !== track.src) {
        audioEl.src = track.src;
        audioEl.load();
      }

      if (startTime > 0) {
        const applyStartTime = () => {
          try {
            audioEl.currentTime = startTime;
          } catch {
            /* ignore */
          }
          clearReadyHandler(audioEl);
        };

        if (audioEl.readyState >= 1) {
          applyStartTime();
        } else {
          readyHandlers.set(audioEl, applyStartTime);
          audioEl.addEventListener('loadedmetadata', applyStartTime);
        }
      } else {
        try {
          audioEl.currentTime = 0;
        } catch {
          /* ignore */
        }
      }

      try {
        audioEl.muted = false;
        audioEl.volume = 0;
      } catch {
        /* ignore */
      }
    }

    function ensureAudioReady(audioEl, onReady) {
      if (audioEl.readyState >= 2) {
        onReady();
        return;
      }

      const handleReady = () => {
        clearReadyHandler(audioEl);
        onReady();
      };

      clearReadyHandler(audioEl);
      readyHandlers.set(audioEl, handleReady);
      audioEl.addEventListener('canplay', handleReady);
    }

    function preloadNextTrack() {
      if (tracks.length <= 1) return;

      clearPreloadTimer();
      preloadTimer = window.setTimeout(function () {
        preloadTimer = null;

        if (switchTargetIndex !== null) return;

        const nextIndex = (index + 1) % tracks.length;
        if (audioTrackIndex.get(inactiveAudio) === nextIndex) return;

        pauseElement(inactiveAudio);
        loadTrack(inactiveAudio, nextIndex);
      }, PRELOAD_DELAY_MS);
    }

    function finalizeSwitch(nextIndex, incomingAudio, outgoingAudio) {
      pauseElement(outgoingAudio);
      activeAudio = incomingAudio;
      inactiveAudio = outgoingAudio;
      index = nextIndex;
      switchTargetIndex = null;

      try {
        activeAudio.volume = getTargetVolume();
        activeAudio.muted = false;
      } catch {
        /* ignore */
      }

      setTitle(index);
      syncPlayUi(isAudioPlaying(activeAudio));
      preloadNextTrack();
      writeStore({ index, t: Math.max(0, activeAudio.currentTime || 0), intent: userPaused ? 'pause' : 'play' });
    }

    function playWithFade(useMutedAutoplay = false) {
      clearAllFades();
      clearPreloadTimer();
      switchTargetIndex = null;

      try {
        activeAudio.muted = useMutedAutoplay;
        activeAudio.volume = 0;
      } catch {
        /* ignore */
      }

      const playPromise = activeAudio.play();

      syncPlayUi(true);

      const handleStarted = () => {
        autoplayBlocked = false;
        resumeAfterReturn = false;
        if (!useMutedAutoplay) {
          try {
            activeAudio.muted = false;
          } catch {
            /* ignore */
          }
        }
        fadeVolumeTo(activeAudio, getTargetVolume(), FADE_IN_MS);
        preloadNextTrack();
      };

      if (playPromise && typeof playPromise.then === 'function') {
        playPromise.then(handleStarted).catch(() => {
          autoplayBlocked = true;
          syncPlayUi(false);
        });
        return;
      }

      handleStarted();
    }

    function startAutoplayFlow() {
      if (userPaused) return;
      autoplayBlocked = false;
      playWithFade(true);
    }

    function switchTrack(nextIndex) {
      if (!tracks[nextIndex]) return;

      clearAllFades();
      clearBlurPauseTimer();
      clearPreloadTimer();

      const wasPlaying = isAudioPlaying(activeAudio);
      switchTargetIndex = nextIndex;

      if (!wasPlaying) {
        pauseElement(inactiveAudio);
        loadTrack(activeAudio, nextIndex);
        index = nextIndex;
        switchTargetIndex = null;
        userPaused = false;
        setTitle(index);
        syncPlayUi(false);
        preloadNextTrack();
        writeStore({ index, t: 0, intent: 'pause' });
        return;
      }

      const outgoingAudio = activeAudio;
      const incomingAudio = inactiveAudio;

      pauseElement(incomingAudio);
      loadTrack(incomingAudio, nextIndex);

      ensureAudioReady(incomingAudio, function () {
        if (switchTargetIndex !== nextIndex) return;

        try {
          incomingAudio.muted = false;
          incomingAudio.volume = 0;
        } catch {
          /* ignore */
        }

        const playPromise = incomingAudio.play();

        const handleStarted = () => {
          autoplayBlocked = false;
          resumeAfterReturn = false;
          setTitle(nextIndex);
          syncPlayUi(true);
          fadeVolumeTo(incomingAudio, getTargetVolume(), SWITCH_FADE_MS);
          fadeVolumeTo(outgoingAudio, 0, SWITCH_FADE_MS, function () {
            if (switchTargetIndex !== nextIndex) return;
            finalizeSwitch(nextIndex, incomingAudio, outgoingAudio);
          });
        };

        if (playPromise && typeof playPromise.then === 'function') {
          playPromise.then(handleStarted).catch(() => {
            switchTargetIndex = null;
            pauseElement(incomingAudio);
            autoplayBlocked = true;
            syncPlayUi(isAudioPlaying(outgoingAudio));
          });
          return;
        }

        handleStarted();
      });
    }

    function pauseForReturn() {
      if (!activeAudio) return;

      clearBlurPauseTimer();

      const wasPlaying = isAudioPlaying(activeAudio) || isAudioPlaying(inactiveAudio);
      if (wasPlaying && !userPaused) {
        resumeAfterReturn = true;
      }

      writeStore();
      pauseImmediatelyOnLeave();
    }

    function resumeFromReturn() {
      clearBlurPauseTimer();
      if (document.hidden || !resumeAfterReturn || userPaused || isAudioPlaying(activeAudio) || isAudioPlaying(inactiveAudio)) return;
      if (typeof document.hasFocus === 'function' && !document.hasFocus()) return;
      playWithFade(true);
      writeStore({ intent: 'play' });
    }

    function pauseImmediatelyOnLeave() {
      if (!activeAudio) return;

      clearBlurPauseTimer();
      clearPreloadTimer();
      clearAllFades();
      syncPlayUi(false);
      pauseElement(primaryAudio);
      pauseElement(secondaryAudio);
      switchTargetIndex = null;
    }

    function pauseWithFade(markUserPaused) {
      if (!activeAudio) return;

      if (markUserPaused) {
        userPaused = true;
        resumeAfterReturn = false;
      }

      syncPlayUi(false);
      clearPreloadTimer();

      const playingPrimary = isAudioPlaying(primaryAudio);
      const playingSecondary = isAudioPlaying(secondaryAudio);

      switchTargetIndex = null;

      if (!playingPrimary && !playingSecondary) {
        pauseElement(primaryAudio);
        pauseElement(secondaryAudio);
        return;
      }

      if (playingPrimary) {
        fadeVolumeTo(primaryAudio, 0, FADE_OUT_MS, function () {
          pauseElement(primaryAudio);
        });
      }

      if (playingSecondary) {
        fadeVolumeTo(secondaryAudio, 0, FADE_OUT_MS, function () {
          pauseElement(secondaryAudio);
        });
      }
    }

    function go(delta) {
      switchTrack((index + delta + tracks.length) % tracks.length);
    }

    function handleAnyPlay() {
      syncPlayUi(true);
      autoplayBlocked = false;
    }

    function handleAnyPause() {
      if (isAudioPlaying(primaryAudio) || isAudioPlaying(secondaryAudio)) return;
      syncPlayUi(false);
    }

    function handleEnded(audioEl) {
      if (audioEl !== activeAudio || activeAudio.loop) return;

      try {
        activeAudio.currentTime = 0;
      } catch {
        /* ignore */
      }

      if (!userPaused) {
        playWithFade(false);
      }
    }

    function handleError(audioEl) {
      if (audioEl !== activeAudio && audioEl !== inactiveAudio) return;
      autoplayBlocked = true;
      if (!isAudioPlaying(primaryAudio) && !isAudioPlaying(secondaryAudio)) {
        syncPlayUi(false);
      }
    }

    function initPlayer() {
      const saved = readStore();
      if (volInput) {
        volInput.value = String(saved && typeof saved.vol === 'number' ? Math.max(0, Math.min(100, saved.vol)) : DEFAULT_VOLUME);
      }

      const startT = saved && typeof saved.t === 'number' ? Math.max(0, saved.t) : 0;
      index = saved && typeof saved.index === 'number'
        ? Math.max(0, Math.min(saved.index, tracks.length - 1))
        : 0;

      loadTrack(activeAudio, index, startT > 0.5 ? startT : 0);
      pauseElement(inactiveAudio);

      userPaused = saved?.intent === 'pause';
      resumeAfterReturn = false;
      setControlsEnabled(true);
      setTitle(index);

      try {
        activeAudio.volume = getTargetVolume();
      } catch {
        /* ignore */
      }

      preloadNextTrack();

      if (!userPaused) {
        startAutoplayFlow();
      } else {
        syncPlayUi(false);
      }

      writeStore();
    }

    prevBtn?.addEventListener('click', () => go(-1));
    nextBtn?.addEventListener('click', () => go(1));

    toggleBtn?.addEventListener('click', () => {
      if (!activeAudio) return;
      if (isAudioPlaying(primaryAudio) || isAudioPlaying(secondaryAudio)) {
        pauseWithFade(true);
        writeStore();
      } else {
        userPaused = false;
        playWithFade(false);
        writeStore();
      }
    });

    volInput?.addEventListener('input', () => {
      const volume = getTargetVolume();

      try {
        activeAudio.volume = volume;
      } catch {
        /* ignore */
      }

      if (switchTargetIndex !== null && isAudioPlaying(inactiveAudio)) {
        try {
          inactiveAudio.volume = Math.min(volume, getCurrentVolume(inactiveAudio));
        } catch {
          /* ignore */
        }
      }

      writeStore();
    });

    primaryAudio.addEventListener('play', handleAnyPlay);
    secondaryAudio.addEventListener('play', handleAnyPlay);
    primaryAudio.addEventListener('pause', handleAnyPause);
    secondaryAudio.addEventListener('pause', handleAnyPause);
    primaryAudio.addEventListener('ended', function () {
      handleEnded(primaryAudio);
    });
    secondaryAudio.addEventListener('ended', function () {
      handleEnded(secondaryAudio);
    });
    primaryAudio.addEventListener('error', function () {
      handleError(primaryAudio);
    });
    secondaryAudio.addEventListener('error', function () {
      handleError(secondaryAudio);
    });

    document.addEventListener(
      'pointerdown',
      function onceTryPlay() {
        if (autoplayBlocked && !userPaused && !isAudioPlaying(primaryAudio) && !isAudioPlaying(secondaryAudio)) {
          playWithFade(false);
        }
      },
      { passive: true }
    );

    document.addEventListener('visibilitychange', function () {
      clearBlurPauseTimer();

      if (document.hidden) {
        if (isInternalNavigationPending()) return;
        pauseForReturn();
        return;
      }

      resumeFromReturn();
    });

    window.addEventListener('focus', function () {
      resumeFromReturn();
    });

    window.addEventListener('blur', function () {
      clearBlurPauseTimer();

      blurPauseTimer = window.setTimeout(function () {
        blurPauseTimer = null;
        if (!shouldPauseForBlur()) return;
        pauseForReturn();
      }, BLUR_PAUSE_DELAY_MS);
    });

    window.addEventListener('pagehide', function () {
      if (isInternalNavigationPending()) return;
      writeStore();
      pauseImmediatelyOnLeave();
    });

    window.addEventListener('beforeunload', function () {
      if (isInternalNavigationPending()) return;
      writeStore();
      pauseImmediatelyOnLeave();
    });

    window.addEventListener('pageshow', function () {
      resumeFromReturn();
    });

    saveTimer = window.setInterval(function () {
      if (!isAudioPlaying(primaryAudio) && !isAudioPlaying(secondaryAudio)) return;
      writeStore();
    }, 3000);

    setControlsEnabled(false);
    initPlayer();
  })();
</script>
