---
import { siteConfig } from '../config/site';

const bm = siteConfig.backgroundMusic;

if (!bm.enabled || bm.tracks.length === 0) {
  return;
}

const barLabel = bm.label ?? 'Now playing';
const tracksEnc = encodeURIComponent(JSON.stringify(bm.tracks));
const firstTitle = bm.tracks[0].title;
const showTrackNav = bm.tracks.length > 1;
---

<div id="music-root" class="music-bar" data-tracks-enc={tracksEnc} role="region" aria-label="Background music">
  <div class="music-bar__inner">
    <div class="music-bar__meta">
      <span class="music-bar__line">
        <span class="music-bar__eyebrow">{barLabel}</span>
        <span class="music-bar__sep" aria-hidden="true">·</span>
        <span id="music-title" class="music-bar__title">{firstTitle}</span>
      </span>
    </div>

    <div class:list={['music-bar__transport', !showTrackNav && 'music-bar__transport--single']}>
      {showTrackNav && (
        <button type="button" class="music-bar__btn" id="music-prev" aria-label="Previous track" title="Previous">
          <svg class="music-bar__icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 18V6h2v12H6zm3.5-6L18 6v12l-8.5-6z"/></svg>
        </button>
      )}
      <button type="button" class="music-bar__btn music-bar__btn--primary" id="music-toggle" aria-label="Pause" title="Pause">
        <svg class="music-bar__icon music-bar__icon--play hidden" id="music-icon-play" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7z"/></svg>
        <svg class="music-bar__icon music-bar__icon--pause" id="music-icon-pause" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 5h4v14H6V5zm8 0h4v14h-4V5z"/></svg>
      </button>
      {showTrackNav && (
        <button type="button" class="music-bar__btn" id="music-next" aria-label="Next track" title="Next">
          <svg class="music-bar__icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16 18h2V6h-2v12zm-9.5-6L15 6v12l-8.5-6z"/></svg>
        </button>
      )}
    </div>

    <div class="music-bar__volume">
      <label class="music-bar__vol-wrap">
        <span class="sr-only">Volume</span>
        <input type="range" id="music-volume" min="0" max="100" value="28" />
      </label>
    </div>
  </div>

  <audio id="music-audio" preload="auto" style="display: none;"></audio>
</div>

<script is:inline>
  (function () {
    const LS = 'allen.bgMusic';
    const NAV = 'allen.site.internalNav';
    const root = document.getElementById('music-root');
    const audio = document.getElementById('music-audio');
    if (!root || !root.dataset.tracksEnc || !(audio instanceof HTMLAudioElement)) return;
    if (root.dataset.initialized === '1') return;

    root.dataset.initialized = '1';

    let tracks;
    try {
      tracks = JSON.parse(decodeURIComponent(root.dataset.tracksEnc));
    } catch {
      return;
    }
    if (!Array.isArray(tracks) || tracks.length === 0) return;

    const titleEl = document.getElementById('music-title');
    const prevBtn = document.getElementById('music-prev');
    const nextBtn = document.getElementById('music-next');
    const toggleBtn = document.getElementById('music-toggle');
    const iconPlay = document.getElementById('music-icon-play');
    const iconPause = document.getElementById('music-icon-pause');
    const volInput = document.getElementById('music-volume');

    const DEFAULT_VOLUME = 28;
    const FADE_IN_MS = 1400;
    const FADE_OUT_MS = 450;
    const FADE_TICK_MS = 50;

    let index = 0;
    let userPaused = false;
    let saveTimer = null;
    let fadeTimer = null;
    let autoplayBlocked = false;
    let resumeAfterReturn = false;

    function isInternalNavigationPending() {
      try {
        return sessionStorage.getItem(NAV) === '1';
      } catch {
        return false;
      }
    }

    function setControlsEnabled(enabled) {
      prevBtn && (prevBtn.disabled = !enabled);
      nextBtn && (nextBtn.disabled = !enabled);
      toggleBtn && (toggleBtn.disabled = !enabled);
      volInput && (volInput.disabled = !enabled);
    }

    function getTargetVolume() {
      return Math.max(0, Math.min(100, Number(volInput?.value) || DEFAULT_VOLUME)) / 100;
    }

    function getCurrentVolume() {
      return Math.max(0, Math.min(1, Number(audio.volume) || 0));
    }

    function clearFade() {
      if (fadeTimer) {
        window.clearInterval(fadeTimer);
        fadeTimer = null;
      }
    }

    function fadeVolumeTo(target, duration, onDone) {
      if (!audio) {
        onDone?.();
        return;
      }

      clearFade();

      const safeTarget = Math.max(0, Math.min(1, target));
      const from = getCurrentVolume();
      const delta = safeTarget - from;

      if (Math.abs(delta) < 0.01) {
        try {
          if (safeTarget > 0) audio.muted = false;
          audio.volume = safeTarget;
        } catch {
          /* ignore */
        }
        onDone?.();
        return;
      }

      const startedAt = Date.now();

      fadeTimer = window.setInterval(function () {
        const progress = Math.min(1, (Date.now() - startedAt) / duration);
        const next = from + delta * progress;

        try {
          if (safeTarget > 0) audio.muted = false;
          audio.volume = Math.max(0, Math.min(1, next));
        } catch {
          clearFade();
          onDone?.();
          return;
        }

        if (progress >= 1) {
          clearFade();
          try {
            if (safeTarget > 0) audio.muted = false;
            audio.volume = safeTarget;
          } catch {
            /* ignore */
          }
          onDone?.();
        }
      }, FADE_TICK_MS);
    }

    function readStore() {
      try {
        const raw = localStorage.getItem(LS);
        if (!raw) return null;
        return JSON.parse(raw);
      } catch {
        return null;
      }
    }

    function writeStore(overrides) {
      try {
        const payload = {
          index,
          t: Math.max(0, audio.currentTime || 0),
          intent: userPaused ? 'pause' : 'play',
          vol: volInput ? Number(volInput.value) || DEFAULT_VOLUME : DEFAULT_VOLUME,
          at: Date.now(),
          ...overrides
        };
        localStorage.setItem(LS, JSON.stringify(payload));
      } catch {
        /* ignore */
      }
    }

    function setTitle() {
      if (titleEl && tracks[index]) titleEl.textContent = tracks[index].title;
    }

    function syncPlayUi(playing) {
      if (!toggleBtn) return;
      toggleBtn.setAttribute('aria-label', playing ? 'Pause' : 'Play');
      toggleBtn.setAttribute('title', playing ? 'Pause' : 'Play');
      iconPlay?.classList.toggle('hidden', !!playing);
      iconPause?.classList.toggle('hidden', !playing);
    }

    function loadTrack(nextIndex, startTime = 0) {
      if (!tracks[nextIndex]) return;

      index = nextIndex;
      audio.src = tracks[index].src;
      audio.loop = tracks.length <= 1;
      audio.load();
      setTitle();

      if (startTime > 0) {
        const applyStartTime = () => {
          try {
            audio.currentTime = startTime;
          } catch {
            /* ignore */
          }
          audio.removeEventListener('loadedmetadata', applyStartTime);
        };

        audio.addEventListener('loadedmetadata', applyStartTime);
      }
    }

    function playWithFade(useMutedAutoplay = false) {
      clearFade();

      try {
        audio.muted = useMutedAutoplay;
        audio.volume = 0;
      } catch {
        /* ignore */
      }

      const playPromise = audio.play();

      syncPlayUi(true);

      const handleStarted = () => {
        autoplayBlocked = false;
        resumeAfterReturn = false;
        if (!useMutedAutoplay) {
          try {
            audio.muted = false;
          } catch {
            /* ignore */
          }
        }
        fadeVolumeTo(getTargetVolume(), FADE_IN_MS);
      };

      if (playPromise && typeof playPromise.then === 'function') {
        playPromise.then(handleStarted).catch(() => {
          autoplayBlocked = true;
          syncPlayUi(false);
        });
        return;
      }

      handleStarted();
    }

    function startAutoplayFlow() {
      if (userPaused) return;
      autoplayBlocked = false;
      playWithFade(true);
    }

    function pauseForReturn() {
      if (!audio) return;

      const wasPlaying = !audio.paused;
      if (wasPlaying && !userPaused) {
        resumeAfterReturn = true;
      }

      writeStore();
      pauseImmediatelyOnLeave();
    }

    function resumeFromReturn() {
      if (!resumeAfterReturn || userPaused || !audio.paused) return;
      playWithFade(true);
      writeStore({ intent: 'play' });
    }

    function pauseImmediatelyOnLeave() {
      if (!audio) return;

      clearFade();
      syncPlayUi(false);

      try {
        audio.volume = 0;
        audio.pause();
      } catch {
        /* ignore */
      }
    }

    function pauseWithFade(markUserPaused) {
      if (!audio) return;

      if (markUserPaused) {
        userPaused = true;
        resumeAfterReturn = false;
      }

      syncPlayUi(false);

      fadeVolumeTo(0, FADE_OUT_MS, function () {
        try {
          audio.pause();
        } catch {
          /* ignore */
        }
      });
    }

    function go(delta) {
      const wasActive = !audio.paused;

      const startNextTrack = () => {
        loadTrack((index + delta + tracks.length) % tracks.length);
        userPaused = false;

        if (wasActive) {
          window.setTimeout(function () {
            playWithFade(false);
          }, 220);
        } else {
          syncPlayUi(false);
        }

        writeStore();
      };

      if (wasActive) {
        pauseWithFade(false);
        window.setTimeout(startNextTrack, FADE_OUT_MS + 30);
        return;
      }

      startNextTrack();
    }

    audio.addEventListener('play', function () {
      syncPlayUi(true);
      autoplayBlocked = false;
      resumeAfterReturn = false;
    });

    audio.addEventListener('pause', function () {
      syncPlayUi(false);
    });

    audio.addEventListener('ended', function () {
      if (tracks.length <= 1) {
        userPaused = false;
        window.setTimeout(function () {
          startAutoplayFlow();
        }, 120);
        writeStore();
        return;
      }
      go(1);
    });

    audio.addEventListener('error', function () {
      autoplayBlocked = true;
      syncPlayUi(false);
    });

    function initPlayer() {
      const saved = readStore();
      if (volInput) {
        volInput.value = String(DEFAULT_VOLUME);
      }
      audio.volume = getTargetVolume();

      const startT = saved && typeof saved.t === 'number' ? Math.max(0, saved.t) : 0;
      index = saved && typeof saved.index === 'number'
        ? Math.max(0, Math.min(saved.index, tracks.length - 1))
        : 0;

      loadTrack(index, startT > 0.5 ? startT : 0);

      userPaused = false;
      resumeAfterReturn = false;
      setControlsEnabled(true);
      startAutoplayFlow();
      writeStore();
    }

    prevBtn?.addEventListener('click', () => go(-1));
    nextBtn?.addEventListener('click', () => go(1));

    toggleBtn?.addEventListener('click', () => {
      if (!audio) return;
      if (!audio.paused) {
        pauseWithFade(true);
        writeStore();
      } else {
        userPaused = false;
        playWithFade(false);
        writeStore();
      }
    });

    volInput?.addEventListener('input', () => {
      audio.volume = getTargetVolume();
      writeStore();
    });

    document.addEventListener(
      'pointerdown',
      function onceTryPlay() {
        if (autoplayBlocked && !userPaused && audio.paused) {
          playWithFade(false);
        }
      },
      { passive: true }
    );

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        if (isInternalNavigationPending()) return;
        pauseForReturn();
        return;
      }

      resumeFromReturn();
    });

    window.addEventListener('focus', function () {
      resumeFromReturn();
    });

    window.addEventListener('pagehide', function () {
      if (isInternalNavigationPending()) return;
      writeStore();
      pauseImmediatelyOnLeave();
    });

    window.addEventListener('beforeunload', function () {
      writeStore();
      pauseImmediatelyOnLeave();
    });

    window.addEventListener('pageshow', function () {
      resumeFromReturn();
    });

    saveTimer = window.setInterval(function () {
      if (!audio || audio.paused) return;
      writeStore();
    }, 3000);

    setControlsEnabled(false);
    initPlayer();
  })();
</script>
